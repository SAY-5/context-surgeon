{
  "name": "context-surgeon",
  "version": "0.1.0",
  "description": "Audit what Claude Code actually loads into context before you type.",
  "homepage": "https://github.com/SAY-5/context-surgeon",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SAY-5/context-surgeon.git"
  },
  "bugs": {
    "url": "https://github.com/SAY-5/context-surgeon/issues"
  },
  "author": "Sai Asish Y <say.apm35@gmail.com>",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "tokens",
    "context",
    "audit",
    "llm",
    "cli",
    "developer-tools"
  ],
  "type": "module",
  "bin": {
    "context-surgeon": "bin/context-surgeon.mjs"
  },
  "main": "dist/cli/index.js",
  "exports": {
    ".": "./dist/cli/index.js"
  },
  "files": [
    "bin/",
    "dist/",
    "assets/fonts/",
    "assets/hero.png",
    "skill-package/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@resvg/resvg-js": "^2.6.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
